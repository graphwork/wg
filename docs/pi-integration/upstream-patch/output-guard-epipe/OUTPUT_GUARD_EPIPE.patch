index 0000000..ad40e56
--- /dev/null
+++ b/packages/coding-agent/test/output-guard.test.ts
@@ -0,0 +1,141 @@
+import { afterEach, beforeEach, describe, expect, it, vi } from "vitest";
+
+const originalStdoutWrite = process.stdout.write;
+let restoreGuard: (() => void) | undefined;
+
+async function loadOutputGuard() {
+	vi.resetModules();
+	const guard = await import("../src/core/output-guard.ts");
+	restoreGuard = guard.restoreStdout;
+	return guard;
+}
+
+function callbackForWrite(
+	encodingOrCallback?: BufferEncoding | ((error?: Error | null) => void),
+	callback?: (error?: Error | null) => void,
+): ((error?: Error | null) => void) | undefined {
+	return typeof encodingOrCallback === "function" ? encodingOrCallback : callback;
+}
+
+beforeEach(() => {
+	process.stdout.write = originalStdoutWrite;
+	restoreGuard = undefined;
+});
+
+afterEach(() => {
+	restoreGuard?.();
+	process.stdout.write = originalStdoutWrite;
+	vi.restoreAllMocks();
+	vi.useRealTimers();
+});
+
+describe("output guard", () => {
+	it("treats a closed stdout reader as a graceful terminal condition", async () => {
+		const brokenPipe = Object.assign(new Error("write EPIPE"), { code: "EPIPE" });
+		const exit = vi.spyOn(process, "exit").mockImplementation((() => undefined) as never);
+		vi.spyOn(process.stdout, "write").mockImplementation(((
+			_chunk: string | Uint8Array,
+			encodingOrCallback?: BufferEncoding | ((error?: Error | null) => void),
+			callback?: (error?: Error | null) => void,
+		) => {
+			const done = callbackForWrite(encodingOrCallback, callback);
+			queueMicrotask(() => {
+				process.stdout.emit("error", brokenPipe);
+				done?.(brokenPipe);
+			});
+			return false;
+		}) as typeof process.stdout.write);
+
+		const { takeOverStdout, waitForRawStdoutBackpressure, writeRawStdout } = await loadOutputGuard();
+		takeOverStdout();
+		writeRawStdout('{"type":"session"}\n');
+
+		await expect(waitForRawStdoutBackpressure()).resolves.toBeUndefined();
+		expect(exit).not.toHaveBeenCalled();
+	});
+
+	it("delivers a complete NDJSON stream including usage", async () => {
+		const chunks: string[] = [];
+		vi.spyOn(process.stdout, "write").mockImplementation(((
+			chunk: string | Uint8Array,
+			encodingOrCallback?: BufferEncoding | ((error?: Error | null) => void),
+			callback?: (error?: Error | null) => void,
+		) => {
+			chunks.push(String(chunk));
+			queueMicrotask(() => callbackForWrite(encodingOrCallback, callback)?.());
+			return true;
+		}) as typeof process.stdout.write);
+
+		const { takeOverStdout, waitForRawStdoutBackpressure, writeRawStdout } = await loadOutputGuard();
+		takeOverStdout();
+		writeRawStdout('{"type":"session","version":3}\n');
+		writeRawStdout('{"type":"turn_start"}\n');
+		writeRawStdout(
+			'{"type":"turn_end","message":{"usage":{"input":7,"output":3,"totalTokens":10,"cost":{"total":0.01}}}}\n',
+		);
+		await waitForRawStdoutBackpressure();
+
+		const events = chunks
+			.join("")
+			.trim()
+			.split("\n")
+			.map((line) => JSON.parse(line));
+		expect(events.map((event) => event.type)).toEqual(["session", "turn_start", "turn_end"]);
+		expect(events[2].message.usage).toEqual({ input: 7, output: 3, totalTokens: 10, cost: { total: 0.01 } });
+	});
+
+	it("retries transient stdout backpressure and preserves order", async () => {
+		let attempts = 0;
+		const chunks: string[] = [];
+		vi.spyOn(process.stdout, "write").mockImplementation(((
+			chunk: string | Uint8Array,
+			encodingOrCallback?: BufferEncoding | ((error?: Error | null) => void),
+			callback?: (error?: Error | null) => void,
+		) => {
+			attempts += 1;
+			const done = callbackForWrite(encodingOrCallback, callback);
+			if (attempts <= 2) {
+				queueMicrotask(() => done?.(Object.assign(new Error("try again"), { code: "EAGAIN" })));
+			} else {
+				chunks.push(String(chunk));
+				queueMicrotask(() => done?.());
+			}
+			return attempts > 2;
+		}) as typeof process.stdout.write);
+
+		const { takeOverStdout, waitForRawStdoutBackpressure, writeRawStdout } = await loadOutputGuard();
+		takeOverStdout();
+		writeRawStdout("first\n");
+		writeRawStdout("second\n");
+		await waitForRawStdoutBackpressure();
+
+		expect(attempts).toBe(4);
+		expect(chunks.join("")).toBe("first\nsecond\n");
+	});
+
+	it("bounds retries when transient stdout backpressure does not clear", async () => {
+		vi.useFakeTimers();
+		let attempts = 0;
+		const exit = vi.spyOn(process, "exit").mockImplementation((() => undefined) as never);
+		vi.spyOn(process.stdout, "write").mockImplementation(((
+			_chunk: string | Uint8Array,
+			encodingOrCallback?: BufferEncoding | ((error?: Error | null) => void),
+			callback?: (error?: Error | null) => void,
+		) => {
+			attempts += 1;
+			callbackForWrite(encodingOrCallback, callback)?.(Object.assign(new Error("still full"), { code: "ENOBUFS" }));
+			return false;
+		}) as typeof process.stdout.write);
+
+		const { takeOverStdout, waitForRawStdoutBackpressure, writeRawStdout } = await loadOutputGuard();
+		takeOverStdout();
+		writeRawStdout("event\n");
+		const settled = waitForRawStdoutBackpressure();
+		const rejection = expect(settled).rejects.toMatchObject({ code: "ENOBUFS" });
+		await vi.runAllTimersAsync();
+		await rejection;
+
+		expect(attempts).toBe(101);
+		expect(exit).toHaveBeenCalledWith(1);
+	});
+});
