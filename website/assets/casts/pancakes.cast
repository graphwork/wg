\u2502\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n\u001b[1m\u001b[38;5;15m\u001b[48;2;30;30;30m Graph\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[1m\u001b[38;2;120;120;120mNAV\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[38;5;3m\u2191\u2193\u001b[38;2;140;140;140m:select  \u001b[38;5;3mEnter\u001b[38;2;140;140;140m:inspect  \u001b[38;5;3mTab\u001b[38;2;140;140;140m:panel  \u001b[38;5;3m/\u001b[38;2;140;140;140m:search  \u001b[38;5;3ma\u001b[38;2;140;140;140m:add  \u001b[38;2;80;80;80m\u2026\u001b[39m\n"]
