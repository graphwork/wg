ikus &&                                      \u001b[38;5;6m‚îÇ\r\n‚îÇ\u001b[39m  wg add \"publish-api\" -d \"REST API serving approved haiku\"    \u001b[38;5;6m‚îÇ\r\n‚îÇ\u001b[39m  --after review-quality,build-pun-db                          \u001b[38;5;6m‚îÇ\r\n‚îÇ\u001b[39m  \u001b[38;5;196m‚ÜØ\u001b[38;5;172m‚ÜØ\u001b[38;5;34m‚ÜØ\u001b[38;5;33m‚ÜØ\u001b[1m\u001b[38;5;129m‚ÜØ\u001b[0m \u001b[38;5;8m13s\u001b[39m                                                    \u001b[38;5;6m‚îÇ\r\n‚îÇ\u001b[39m                                                               \u001b[38;5;6m‚îÇ\r\n‚îÇ\u001b[1m\u001b[38;5;5m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\u001b[0m\u001b[38;5;6m‚îÇ\r\n‚îÇ\u001b[1m\u001b[38;5;13m> \u001b[0m\u001b[38;5;0m\u001b[48;5;15m \u001b[39m\u001b[49m                                                            \u001b[38;5;6m‚îÇ\r\n‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò\r\n\u001b[1m\u001b[38;5;15m\u001b[48;2;30;30;30m 0:Chat\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[1m\u001b[38;5;5mEDIT\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[38;5;3mEnter\u001b[38;2;140;140;140m:send  \u001b[38;5;3mEsc\u001b[38;2;140;140;140m:cancel  \u001b[38;5;3m‚Üë‚Üì\u001b[38;2;140;140;140m:history\u001b[39m"]
