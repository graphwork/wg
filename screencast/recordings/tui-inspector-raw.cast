9m  7. \u001b[1mreview-quality\u001b[0m \u2014 quality gate (after 6)                   \u001b[38;5;8m\u2502\r\n\u2502\u001b[39m  8. \u001b[1mpublish-api\u001b[0m \u2014 REST API (after 7,4)                        \u001b[38;5;8m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;8m\u2502\r\n\u2502\u001b[39m  Creating tasks now...                                        \u001b[38;5;8m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;8m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;8m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;8m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;8m\u2502\r\n\u2502 \u2191\u2193: scroll\u001b[39m                                                    \u001b[38;5;8m\u2502\r\n\u2514\u001b[38;2;85;122;122m\u001b[48;2;9;14;19m \u2193 \u001b[39m\u001b[49m \u001b[1m\u001b[38;2;178;255;255m\u001b[48;2;20;30;40m \u2193 \u001b[0m\u001b[38;5;8m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\r\n\u001b[1m\u001b[38;5;15m\u001b[48;2;30;30;30m Graph\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[1m\u001b[38;2;120;120;120mNAV\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[38;5;3m\u2191\u2193\u001b[38;2;140;140;140m:select  \u001b[38;5;3mEnter\u001b[38;2;140;140;140m:inspect  \u001b[38;5;3mTab\u001b[38;2;140;140;140m:panel  \u001b[38;5;3m/\u001b[38;2;140;140;140m:search  \u001b[38;2;80;80;80m\u2026\u001b[39m"]
